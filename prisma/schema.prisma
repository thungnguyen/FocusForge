// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Mission {
  id           String   @id @default(uuid())
  content      String   @db.Text
  whyStarted   String   @db.Text
  weakestArea  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Goal {
  id          String   @id @default(uuid())
  title       String
  order       Int
  actionsJson String   @db.Text // Serialized JSON of actions: { id: string, text: string }[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DailyRule {
  id        Int      @id @default(autoincrement())
  name      String
  target    String
  createdAt DateTime @default(now())
}

model Week {
  number      Int      @id // Week 1 to 9
  dateRange   String
  brainDump   String   @db.Text
  goalsJson   String   @db.Text // Serialized array of strings: string[]
  status      String   // "Completed" | "In Progress" | "Upcoming"
  progress    Int      @default(0)
  affirmation String?  @db.Text
  reflection  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Day {
  number            Int      @id // Day 1 to 60
  weekNumber        Int
  date              String
  status            String   // "Completed" | "In Progress" | "Upcoming"
  focusArea         String
  mit               String
  prioritiesJson    String   @db.Text // Serialized TaskItem[]
  secondariesJson   String   @db.Text // Serialized TaskItem[]
  mood              String
  energy            String   // "High" | "Medium" | "Low"
  kaizenReflection  String   @db.Text
  completed         Boolean  @default(false)
  timeBlocksJson    String?  @db.Text // Serialized Kaizen slots
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model HabitLog {
  dayNumber     Int      @id // Day 1 to 60
  screenTime    Float    // hrs
  weight        Float    // kg
  sleepTime     Float    // hrs
  wakeUpTime    String
  waterIntake   Float    // L
  workout       Boolean  @default(false)
  reading       Boolean  @default(false)
  english       Boolean  @default(false)
  coding        Boolean  @default(false)
  noSocialMedia Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LifeScore {
  name         String   @id // e.g. Money, Health, Family, etc.
  currentScore Int      @default(0)
  targetScore  Int      @default(0)
  note         String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Ikigai {
  id             String   @id @default(uuid())
  loveJson       String   @db.Text // Serialized string[]
  goodAtJson     String   @db.Text // Serialized string[]
  worldNeedsJson String   @db.Text // Serialized string[]
  paidForJson    String   @db.Text // Serialized string[]
  summary        String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
